@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sa: <https://stellararcana.org/> .

sa:WondrousLikeBaseShape
  a sh:NodeShape ;
  rdfs:comment "LLM generation instruction: write these as socially embedded artifacts. Every generated item should include practical use and societal consequences, not only mechanics." ;
  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sa:description ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sa:commonUsage ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path [ sh:alternativePath ( sa:societalImpact societalImpact ) ] ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "Provide exactly one societal impact field. Prefer sa:societalImpact for new data." ;
  ] ;
  sh:property [
    sh:path sa:rarity ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "common" "uncommon" "rare" "very-rare" "legendary" "artifact" ) ;
  ] ;
  sh:property [
    sh:path sa:cost ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sa:legalStatus ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "legal" "restricted" "illegal" ) ;
  ] ;
  sh:property [
    sh:path sa:origin ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sa:manufacturer ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .

sa:WondrousItemShape
  a sh:NodeShape ;
  sh:targetClass sa:WondrousItem ;
  rdfs:comment "LLM generation instruction: default template for civilian magical objects. Keep tone grounded in everyday use and setting-level consequences." ;
  sh:node sa:WondrousLikeBaseShape .

sa:AlchemicalSubstanceShape
  a sh:NodeShape ;
  sh:targetClass sa:AlchemicalSubstance ;
  rdfs:comment "LLM generation instruction: generate as material chemistry first (paint, reagent, compound), then gameplay effect." ;
  sh:node sa:WondrousLikeBaseShape .

sa:ArcanoTechShape
  a sh:NodeShape ;
  sh:targetClass sa:ArcanoTech ;
  rdfs:comment "LLM generation instruction: generate as hybrid magic-tech devices with clear operational context and infrastructure dependencies." ;
  sh:node sa:WondrousLikeBaseShape .

sa:BoundConstructShape
  a sh:NodeShape ;
  sh:targetClass sa:BoundConstruct ;
  rdfs:comment "LLM generation instruction: generate as semi-autonomous bound entities with explicit service role and governance implications." ;
  sh:node sa:WondrousLikeBaseShape .

sa:AlchemicalItemShape
  a sh:NodeShape ;
  sh:targetClass sa:AlchemicalItem ;
  rdfs:comment "LLM generation instruction: generate as single-use or consumable alchemical products with clear activation pattern and social niche." ;
  sh:node sa:WondrousLikeBaseShape .
